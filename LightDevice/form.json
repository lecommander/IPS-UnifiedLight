{
  "elements": [
    {
      "type": "Select",
      "name": "BackendType",
      "caption": "Backend Type",
      "options": [
        { "caption": "DMX (IPS built-in)",              "value": 0 },
        { "caption": "Shelly Dimmer (IPS-Shelly)",      "value": 1 },
        { "caption": "Zigbee2MQTT (IPS-Zigbee2MQTT)",   "value": 2 },
        { "caption": "KNX (IPS built-in)",              "value": 3 },
        { "caption": "HomeMatic IP (HmIP)",             "value": 4 },
        { "caption": "HomeMatic Funk (HM-RF)",          "value": 5 },
        { "caption": "HomeMatic Wired (HM-Wired)",      "value": 6 },
        { "caption": "Philips Hue (IPS-PhilipsHue-V2)", "value": 7 }
      ]
    },
    {
      "type": "Label",
      "caption": "── DMX Settings (only for Backend Type = DMX) ──────────────",
      "visible": "BackendType == 0"
    },
    {
      "type": "SelectInstance",
      "name": "DMXInstanceID",
      "caption": "DMX Instance",
      "visible": "BackendType == 0"
    },
    {
      "type": "NumberSpinner",
      "name": "DMXChannel",
      "caption": "DMX Channel",
      "minimum": 1,
      "maximum": 512,
      "visible": "BackendType == 0"
    },
    {
      "type": "NumberSpinner",
      "name": "DMXFadeTime",
      "caption": "Fade Time (seconds, 0 = instant)",
      "minimum": 0,
      "maximum": 30,
      "digits": 1,
      "steps": 0.5,
      "visible": "BackendType == 0"
    },
    {
      "type": "Label",
      "caption": "── Shelly / Zigbee2MQTT / Hue Settings (variable-based backends) ──",
      "visible": "BackendType == 1 || BackendType == 2 || BackendType == 7"
    },
    {
      "type": "Label",
      "caption": "Select the Power and Brightness variables from the device instance in the object tree.",
      "visible": "BackendType == 1 || BackendType == 2 || BackendType == 7"
    },
    {
      "type": "SelectVariable",
      "name": "PowerVariableID",
      "caption": "Power Variable (boolean, on/off)",
      "visible": "BackendType == 1 || BackendType == 2 || BackendType == 7"
    },
    {
      "type": "SelectVariable",
      "name": "BrightnessVariableID",
      "caption": "Brightness Variable (integer, 0–100)",
      "visible": "BackendType == 1 || BackendType == 2 || BackendType == 7"
    },
    {
      "type": "Label",
      "caption": "── KNX Settings (only for Backend Type = KNX) ─────────────────",
      "visible": "BackendType == 3"
    },
    {
      "type": "SelectInstance",
      "name": "KNXInstanceID",
      "caption": "KNX Instance",
      "visible": "BackendType == 3"
    },
    {
      "type": "TextField",
      "name": "KNXSwitchAddress",
      "caption": "Switch Group Address (e.g. 1/2/3)",
      "visible": "BackendType == 3"
    },
    {
      "type": "TextField",
      "name": "KNXDimAddress",
      "caption": "Dim Group Address (e.g. 1/2/4)",
      "visible": "BackendType == 3"
    },
    {
      "type": "Label",
      "caption": "── HomeMatic Settings (IP, Funk, Wired) ──────────────────────",
      "visible": "BackendType >= 4 && BackendType <= 6"
    },
    {
      "type": "SelectInstance",
      "name": "HMInstanceID",
      "caption": "HomeMatic Instance (CCU)",
      "visible": "BackendType >= 4 && BackendType <= 6"
    },
    {
      "type": "SelectInstance",
      "name": "HMDeviceID",
      "caption": "Device Instance (Dimmer/Switch)",
      "visible": "BackendType >= 4 && BackendType <= 6"
    },
    {
      "type": "NumberSpinner",
      "name": "HMFadeTime",
      "caption": "Fade Time / RAMP_TIME (seconds, 0 = instant)",
      "minimum": 0,
      "maximum": 60,
      "digits": 1,
      "steps": 0.5,
      "visible": "BackendType >= 4 && BackendType <= 6"
    }
  ],
  "actions": [
    {
      "type": "TestCenter"
    },
    {
      "type": "Label",
      "caption": "Quick Test:"
    },
    {
      "type": "Button",
      "caption": "Turn On (100%)",
      "onClick": "ULIGHT_SetBrightness($id, 100);"
    },
    {
      "type": "Button",
      "caption": "Turn Off",
      "onClick": "ULIGHT_SetPower($id, false);"
    },
    {
      "type": "Button",
      "caption": "50% Brightness",
      "onClick": "ULIGHT_SetBrightness($id, 50);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "Active",
      "caption": "Device configured and active"
    },
    {
      "code": 201,
      "icon": "Warning",
      "caption": "Not configured — check Backend Type and Instance/Variable settings"
    }
  ]
}
